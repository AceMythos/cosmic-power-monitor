<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.AceMythos.cosmic-ext-applet-power-monitor</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Power Monitor for the COSMIC™ Desktop</name>
  <summary>Display real-time battery power draw in watts for the COSMIC™ desktop</summary>
  <description>
    <p>
      A lightweight applet for the COSMIC™ desktop that shows real-time battery
      power consumption directly in the panel. Monitor your power usage at a
      glance with live wattage readings updated every second.
    </p>
    <p>Features:</p>
    <ul>
      <li>Real-time power draw display in watts</li>
      <li>Updates every second via D-Bus</li>
      <li>Lightweight and minimal resource usage</li>
      <li>Integrates seamlessly into the COSMIC panel</li>
    </ul>
  </description>
  <url type="homepage">https://github.com/AceMythos/cosmic-power-monitor</url>
  <url type="bugtracker">https://github.com/AceMythos/cosmic-power-monitor/issues</url>
  <developer id="io.github.AceMythos">
    <name>AceMythos</name>
  </developer>
  <launchable type="desktop-id">io.github.AceMythos.cosmic-ext-applet-power-monitor.desktop</launchable>
  <provides>
    <id>com.system76.CosmicApplet</id>
  </provides>
  <content_rating type="oars-1.1" />
  <releases>
