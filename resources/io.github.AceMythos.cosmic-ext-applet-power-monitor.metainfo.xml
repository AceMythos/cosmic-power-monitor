<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.AceMythos.cosmic-ext-applet-power-monitor</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <name>Power Monitor for the COSMIC™ Desktop</name>
  <summary>Display real-time battery power draw in watts for the COSMIC™ desktop</summary>
  <description>
    <p>
      Shows your laptop's battery draw in watts right on the COSMIC panel. Reads
      from /sys/class/power_supply directly — no daemon, no extra overhead.
      Updates about 4 times a second.
    </p>
    <p>Click the reading for the full picture:</p>
    <ul>
      <li>Current charge percentage</li>
      <li>Charging or discharging status</li>
      <li>Charge/discharge rate in watts</li>
      <li>Total energy capacity and current level</li>
      <li>Estimated time remaining</li>
    </ul>
  </description>
  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/AceMythos/cosmic-power-monitor/main/screenshots/demo.png</image>
      <caption>Power draw showing on the panel</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/AceMythos/cosmic-power-monitor/main/screenshots/popup.png</image>
      <caption>Detailed battery info popup</caption>
    </screenshot>
  </screenshots>
  <url type="homepage">https://github.com/AceMythos/cosmic-power-monitor</url>
  <url type="bugtracker">https://github.com/AceMythos/cosmic-power-monitor/issues</url>
  <developer id="io.github.AceMythos">
    <name>AceMythos</name>
  </developer>
  <launchable type="desktop-id">io.github.AceMythos.cosmic-ext-applet-power-monitor.desktop</launchable>
